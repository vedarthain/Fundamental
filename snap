#!/usr/bin/env bash
# ./snap — full weekly refresh: fetch fundamentals → compute metrics → score.
#
# Default behaviour: scrapes fresh Screener exports for every active stock
# (~15 min), recomputes metrics, and runs the percentile + composite scorer.
# Use this once a week (typically after market close on Friday).
#
# Flags:
#   ./snap                   # full pipeline: fetch + compute + score (today's snapshot)
#   ./snap 2026-05-12        # full pipeline, but pin the snapshot_date
#   ./snap --skip-fetch      # skip fetch-many (quick re-score on existing data; ~10s)
#   ./snap --skip-fetch 2026-05-12
#   ./snap --workers 2       # reduce fetch concurrency (default 3) — use when
#                              Screener rate-limits the default rate
#
# What this does NOT do:
#   - Daily LTP / OHLC refresh — that's refresh-ltp.py via GitHub Actions.
#     LTP is sourced from NSE bhavcopy (the single source of truth). Screener
#     LTP is deliberately ignored by compute-metrics.
#   - Sync to Neon production — run ./scripts/sync-neon.sh after this.

set -eo pipefail

cd "$(dirname "$0")"

PY=etl/.venv/bin/python

# Parse flags / positional args. Supports any order:
#   ./snap, ./snap 2026-05-12, ./snap --skip-fetch, ./snap --workers 2
SKIP_FETCH=0
SNAP=""
WORKERS=""
EXPECT_WORKERS=0
for arg in "$@"; do
  if [ "$EXPECT_WORKERS" -eq 1 ]; then
    WORKERS="$arg"
    EXPECT_WORKERS=0
    continue
  fi
  case "$arg" in
    --skip-fetch) SKIP_FETCH=1 ;;
    --workers)    EXPECT_WORKERS=1 ;;
    --help|-h)
      sed -n '1,20p' "$0"
      exit 0
      ;;
    *) SNAP="$arg" ;;
  esac
done

run() {
  local step="$1"; shift
  echo "▶ $step ${SNAP:-(today)}"
  if [ -n "$SNAP" ]; then
    "$PY" -m fundamental_etl.cli "$step" --snapshot "$SNAP"
  else
    "$PY" -m fundamental_etl.cli "$step"
  fi
}

run_nosnap() {
  # fetch-many doesn't take --snapshot — it always pulls today's Screener data.
  local step="$1"
  echo "▶ $step"
  if [ -n "$WORKERS" ]; then
    "$PY" -m fundamental_etl.cli "$step" --workers "$WORKERS"
  else
    "$PY" -m fundamental_etl.cli "$step"
  fi
}

if [ "$SKIP_FETCH" -eq 0 ]; then
  run_nosnap fetch-many
  echo
fi
run compute-metrics
echo
run score
echo
echo "✓ snapshot complete"
echo
if [ "$SKIP_FETCH" -eq 0 ]; then
  echo "Next: ./scripts/sync-neon.sh to push to production."
fi
